entry : test/gallery.lua
width : 1200
height : 800
high_dpi : true
window_title : "Miru Component Gallery"
background : 0xfff8fafc
extlua_entry : miru_test_init
extlua_preload : miru_test
extlua_material :
	rounded_rect
extlua_material_path : test/material/?.lua
text_sampler :
	min_filter : linear
	mag_filter : linear
	wrap_u : edge
	wrap_v : edge
	wrap_w : edge
